# ─── Environnement ──────────────────────────────────────────────────
# "local" ou "production"
APP_ENV=local

# ─── Base de donnees ────────────────────────────────────────────────
# PostgreSQL (obligatoire)
# Local (Docker via make db) :
DATABASE_URL=postgresql://himalayan:himalayan@localhost:5432/himalayan_450
# Railway (fourni automatiquement par le plugin PostgreSQL) :
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# ─── API ────────────────────────────────────────────────────────────
# Mode debug (logs SQL, stack traces detaillees)
DEBUG=false

# Regex CORS pour les origines autorisees
# Local : autorise tout localhost
CORS_ORIGIN_REGEX=http://localhost:\d+
# Production (Vercel) : remplacer par le domaine reel, ex:
# CORS_ORIGIN_REGEX=https://himalayan-450\.vercel\.app

# ─── Service LBC (mode split) ────────────────────────────────────
# URL du service LBC local pour deleguer le scraping LeBonCoin.
# Si defini, les endpoints LBC de l'API principale sont proxyes vers ce service.
# Le service tourne chez toi (IP residentielle) via `make lbc` ou `make tunnel`.
# LBC_SERVICE_URL=https://lbc.mon-tunnel.com

# ─── Proxy LeBonCoin ──────────────────────────────────────────────
# Alternative au service LBC : proxy residentiel direct.
# Format : http://user:pass@host:port
# LBC_PROXY_URL=http://user:pass@proxy.example.com:8080

# ─── Cloudflare Tunnel ───────────────────────────────────────────
# Token pour le tunnel Cloudflare (utilise par `make tunnel`)
# CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiNjQ...
